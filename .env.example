# Oracle Database
ORACLE_USER=plexus_user
ORACLE_PASSWORD=your_secure_password_here
ORACLE_DSN=hostname:1521/servicename
ORACLE_WALLET_PATH=/path/to/wallet

# OCI Object Storage (Optional for Phase 1, required in Phase 2+)
OCI_NAMESPACE=your_oci_namespace
OCI_BUCKET_NAME=plexus-contracts
OCI_REGION=us-ashburn-1
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT

# Groq API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_HEAVY=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Cohere API
COHERE_API_KEY=your_cohere_api_key_here
COHERE_EMBED_MODEL=embed-english-v3.0

# Auth (generate JWT_SECRET_KEY with: openssl rand -hex 32)
JWT_SECRET_KEY=your_jwt_secret_key_here_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
